{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paa/deconstruction/contracts/Engine.schema.json",
  "title": "Engine Component Contract Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gateway_engine_request",
    "stream_event",
    "model_completion_response",
    "tool_execution_result"
  ],
  "properties": {
    "gateway_engine_request": {
      "$ref": "#/$defs/GatewayEngineRequest"
    },
    "stream_event": {
      "$ref": "#/$defs/StreamEvent"
    },
    "model_completion_response": {
      "$ref": "#/$defs/ModelCompletionResponse"
    },
    "tool_execution_result": {
      "$ref": "#/$defs/ToolExecutionResult"
    }
  },
  "$defs": {
    "Identifier": {
      "type": "string",
      "minLength": 1
    },
    "MessageRole": {
      "type": "string",
      "enum": [
        "system",
        "user",
        "assistant",
        "tool"
      ]
    },
    "GatewayToolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "input"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "GatewayMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "content"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/MessageRole"
        },
        "content": {
          "type": "string"
        },
        "tool_call_id": {
          "$ref": "#/$defs/Identifier"
        },
        "tool_calls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GatewayToolCall"
          }
        }
      }
    },
    "GatewayEngineMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "$ref": "#/$defs/Identifier"
        },
        "conversation_id": {
          "$ref": "#/$defs/Identifier"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "message",
            "webhook",
            "schedule"
          ]
        },
        "client_context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "GatewayEngineRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "messages",
        "metadata"
      ],
      "properties": {
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GatewayMessage"
          }
        },
        "metadata": {
          "$ref": "#/$defs/GatewayEngineMetadata"
        }
      }
    },
    "ModelToolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "input"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ModelCompletionResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assistantText",
        "toolCalls",
        "finishReason"
      ],
      "properties": {
        "assistantText": {
          "type": "string"
        },
        "toolCalls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ModelToolCall"
          }
        },
        "finishReason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ToolExecutionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "output"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "denied",
            "error"
          ]
        },
        "output": {},
        "recoverable": {
          "type": "boolean"
        }
      }
    },
    "StreamEventTextDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "delta"
      ],
      "properties": {
        "type": {
          "const": "text-delta"
        },
        "delta": {
          "type": "string"
        }
      }
    },
    "StreamEventToolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id",
        "name",
        "input"
      ],
      "properties": {
        "type": {
          "const": "tool-call"
        },
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "StreamEventToolResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id",
        "status",
        "output"
      ],
      "properties": {
        "type": {
          "const": "tool-result"
        },
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "denied",
            "error"
          ]
        },
        "output": {}
      }
    },
    "StreamEventApprovalRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "request_id",
        "tool_name",
        "summary"
      ],
      "properties": {
        "type": {
          "const": "approval-request"
        },
        "request_id": {
          "$ref": "#/$defs/Identifier"
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "StreamEventApprovalResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "request_id",
        "decision"
      ],
      "properties": {
        "type": {
          "const": "approval-result"
        },
        "request_id": {
          "$ref": "#/$defs/Identifier"
        },
        "decision": {
          "type": "string",
          "enum": [
            "approved",
            "denied"
          ]
        }
      }
    },
    "StreamEventDone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "conversation_id",
        "message_id",
        "finish_reason"
      ],
      "properties": {
        "type": {
          "const": "done"
        },
        "conversation_id": {
          "$ref": "#/$defs/Identifier"
        },
        "message_id": {
          "$ref": "#/$defs/Identifier"
        },
        "finish_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "StreamEventError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "code",
        "message"
      ],
      "properties": {
        "type": {
          "const": "error"
        },
        "code": {
          "type": "string",
          "enum": [
            "provider_error",
            "tool_error",
            "context_overflow"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "StreamEvent": {
      "oneOf": [
        {
          "$ref": "#/$defs/StreamEventTextDelta"
        },
        {
          "$ref": "#/$defs/StreamEventToolCall"
        },
        {
          "$ref": "#/$defs/StreamEventToolResult"
        },
        {
          "$ref": "#/$defs/StreamEventApprovalRequest"
        },
        {
          "$ref": "#/$defs/StreamEventApprovalResult"
        },
        {
          "$ref": "#/$defs/StreamEventDone"
        },
        {
          "$ref": "#/$defs/StreamEventError"
        }
      ]
    }
  }
}
